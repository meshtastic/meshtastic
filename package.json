{
  "name": "meshtastic",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "pdf": "npx docusaurus-prince-pdf -u http://localhost:3000/docs/about/ --dest ./static/documents/pdf --output ./static/documents/pdf/Meshtastic-Documentation.pdf",
    "write-translations": "docusaurus write-translations",
    "crowdin": "crowdin",
    "crowdin:upload": "crowdin upload",
    "crowdin:download": "crowdin download",
    "crowdin:sync": "docusaurus write-translations && crowdin upload && crowdin download",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:mdx": "bash scripts/lint-mdx.sh",
    "lint:mdx:strict": "eslint --no-warn-ignored 'docs/**/*.mdx' 'i18n/**/*.mdx'",
    "format:fix": "oxfmt .",
    "format": "oxfmt --check .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@algolia/client-search": "^5.55.2",
    "@crowdin/cli": "^4.14.3",
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "^3.10.2",
    "@docusaurus/plugin-content-blog": "^3.10.2",
    "@docusaurus/plugin-content-docs": "3.10.2",
    "@docusaurus/plugin-vercel-analytics": "^3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/theme-common": "3.10.2",
    "@docusaurus/theme-mermaid": "3.10.2",
    "@giscus/react": "^3.1.0",
    "@heroicons/react": "^2.2.0",
    "@iconify/react": "^6.0.2",
    "@mdx-js/react": "^3.1.1",
    "@mermaid-js/layout-elk": "^0.2.2",
    "@meshtastic/core": "jsr:^2.6.6",
    "@meshtastic/protobufs": "jsr:^2.7.26",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "autoprefixer": "^10.5.3",
    "base64-js": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "katex": "^0.18.0",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.17",
    "react": "^19.2.7",
    "react-accessible-accordion": "^5.0.1",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-player": "^3.4.0",
    "remark-deflist": "^1.0.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tsconfig/docusaurus": "^2.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "docusaurus-prince-pdf": "^1.2.1",
    "eslint": "^10.7.0",
    "eslint-plugin-mdx": "^3.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint",
      "oxfmt"
    ]
  }
}
